{
  "name": "Seagrass",
  "scopeName": "source.seagrass",
  "fileTypes": ["sg"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#calls" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.seagrass",
          "match": "//.*$"
        },
        {
          "name": "comment.line.number-sign.seagrass",
          "match": "#.*$"
        },
        {
          "name": "comment.block.seagrass",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.seagrass",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.seagrass",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.seagrass",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.seagrass",
          "match": "\\b(import|function|class|return|new|if|else|for|in|by)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.variable.builtin.seagrass",
          "match": "__[A-Z_]+__"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.seagrass",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "captures": {
            "1": { "name": "support.type.module.seagrass" },
            "2": { "name": "punctuation.accessor.dot.seagrass" },
            "3": { "name": "entity.name.function.seagrass" }
          },
          "match": "\\b([a-z_][A-Za-z0-9_]*)(\\.)([a-z_][A-Za-z0-9_]*)\\b"
        },
        {
          "captures": {
            "1": { "name": "entity.name.function.seagrass" }
          },
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
